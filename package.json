{
  "name": "hedera-agent-commerce-protocol",
  "version": "0.1.0",
  "description": "Decentralized agent-to-agent marketplace on Hedera using HCS, HSCS, and HTS",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:staking": "hardhat test test/ReputationStaking.test.ts",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network hedera_testnet",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "demo": "hardhat run scripts/demo-integration.ts --network hardhat",
    "demo:testnet": "hardhat run scripts/demo-integration.ts --network hedera_testnet",
    "hcs:create-topic": "ts-node scripts/create-hcs-topic.ts",
    "typecheck": "tsc --noEmit",
    "sdk:build": "tsc --outDir dist --declaration",
    "cli": "ts-node cli/hacp.ts",
    "ai-demo": "ts-node --transpile-only scripts/ai-agent-demo.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.0.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hashgraph/sdk": "^2.51.0",
    "@openzeppelin/contracts": "^5.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0"
  }
}
